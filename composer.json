{
    "name": "sazar/prosdevis",
    "description": "Application web de devis professionnels PHP/MySQL",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "dompdf/dompdf": "^2.0",
        "phpmailer/phpmailer": "^6.9",
        "firebase/php-jwt": "^6.10",
        "intervention/image": "^3.7",
        "bacon/bacon-qr-code": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
