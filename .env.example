# === ProsDevis — Configuration environnement ===
# Copier ce fichier en .env et adapter les valeurs

APP_ENV=production
APP_DEBUG=false
APP_URL=https://votre-domaine.fr

# Base de données
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=prosdevis
DB_USER=prosdevis_user
DB_PASS=motdepasse_securise

# --- Email driver ---
# Choisir : smtp | brevo | mailgun | mail
MAIL_DRIVER=smtp
MAIL_FROM=noreply@votre-domaine.fr
MAIL_FROM_NAME=ProsDevis

# SMTP (driver = smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls

# Brevo / Sendinblue (driver = brevo)
BREVO_API_KEY=

# Mailgun (driver = mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.votre-domaine.fr
MAILGUN_REGION=eu
