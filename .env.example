# Application
APP_NAME=ProsDevis
APP_URL=https://prosdevis.local
APP_ENV=development
APP_DEBUG=true
APP_SECRET=change_this_to_a_random_32_char_string

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=prosdevis
DB_USER=root
DB_PASS=

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@prosdevis.fr
MAIL_FROM_NAME=ProsDevis

# JWT
JWT_SECRET=change_this_too
JWT_EXPIRY=3600

# HelloSign (optionnel)
HELLOSIGN_API_KEY=

# Uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=storage/logos/
